# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Límites
MAX_UPLOAD_BYTES=26214400
CHAT_REQUESTS_PER_MINUTE=20
# Define los precios vigentes del proveedor para calcular costes en /admin.
CHAT_INPUT_COST_USD_PER_MILLION=0
CHAT_OUTPUT_COST_USD_PER_MILLION=0

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@example.com
DEMO_USER_EMAIL=demo@example.com
E2E_USER_EMAIL=demo@example.com
E2E_USER_PASSWORD=change-me
CRON_SECRET=replace-with-a-long-random-secret
